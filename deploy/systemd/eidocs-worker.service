[Unit]
Description=EI Docs one-shot ingest worker
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/eidocs/current
Environment=EIDOCS_ROOT=/var/lib/eidocs
Environment=EIDOCS_CONFIG_DIR=/etc/eidocs
Environment=EIDOCS_ENV_FILE=/etc/eidocs/api-keys.env
Environment=EIDOCS_OLLAMA_HOST=http://honjia:11434
Environment=EIDOCS_OLLAMA_EMBED_MODEL=mxbai-embed-large:latest
Environment=EIDOCS_EMBEDDING_DIM=1024
Environment=EIDOCS_RAG_INDEX=1
Environment=EIDOCS_RAG_PYTHON=/opt/eidocs/rag-venv/bin/python
ExecStart=/opt/eidocs/current/.venv/bin/eidocs job run-once --limit 1 --storage /var/lib/eidocs
StandardOutput=append:/var/log/eidocs/worker.service.log
StandardError=append:/var/log/eidocs/worker.service.log
Nice=10
NoNewPrivileges=yes
PrivateTmp=yes
MemoryMax=3G
CPUQuota=150%
TasksMax=128
